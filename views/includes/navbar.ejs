<style>
  /* 1. Fix the Overlap: Make sure navbar has a solid background and height */
  .navbar {
    background-color: white !important;
    z-index: 1000 !important;
    width: 100%;
  }

  /* 2. Fix the Search Bar: Make it fit on one line or stack nicely */
  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1rem;
    font-size: 0.9rem;
    width: 100%; /* Important for mobile */
  }

  .search-btn {
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0.5rem 1.2rem;
    border: none;
  }

  /* 3. Mobile Specific Fixes */
  @media (max-width: 768px) {
    /* Ensure the menu pushes content down instead of floating over it */
    .navbar-collapse {
      background-color: white;
      padding: 1rem;
      border-bottom: 1px solid #ddd;
    }

    /* Stack buttons and links vertically with spacing */
    .navbar-nav {
      display: flex;
      flex-direction: column;
      align-items: center; /* Center everything in mobile menu */
      gap: 10px;
    }

    .nav-link-a {
      width: 100%;
      text-align: center;
      background-color: #fe424d;
      color: white !important;
      border-radius: 25px;
      padding: 0.8rem;
      margin: 5px 0;
      text-decoration: none;
    }

    /* Fix the search form layout in mobile menu */
    #nav-search-form {
      width: 100%;
      display: flex;
      gap: 5px;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-white border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass" style="color: #fe424d; font-size: 2rem;"></i>
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav w-100">
        <!-- Explore Link -->
        <a class="nav-link" href="/listings">Explore</a>

        <!-- Search Form -->
        <div class="mx-auto" style="width: 100%; max-width: 400px;">
          <form id="nav-search-form" class="d-flex" role="search" method="GET" action="/listings">
            <input id="nav-search-input" name="country" class="form-control search-inp" type="search" placeholder="Search destination">
            <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i></button>
          </form>
        </div>

        <!-- Right Side Links -->
        <div class="d-flex flex-column flex-md-row align-items-center gap-2">
          <a class="nav-link-a" href="/listings/new">Airbnb your home</a>
          
          <% if(!currUser){ %>
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
            <a class="nav-link" href="/login"><b>Log in</b></a>
          <% } else { %>
            <a class="nav-link" href="/logout"><b>Log out</b></a>
          <% } %>

          <a class="nav-link position-relative" href="/cart">
            <i class="fa-solid fa-shopping-cart"></i> Cart
            <span class="badge bg-danger position-absolute top-0 start-100 translate-middle">
              <%= (typeof cartCount !== 'undefined') ? cartCount : 0 %>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>
