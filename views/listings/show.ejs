

<% layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-8 offset-3">
        <h3><%= listing.title %></h3>
    </div>

    <div class="card col-6 offset-3 show-card listing-card">
        <span id="listing-price" style="display:none;"><%= listing.price %></span>
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
        <div class="card-body">
            <p><i>Owned By - <%= listing.owner ? listing.owner.username : "Unknown" %></i></p>
            <p><%= listing.description %></p>
            <p>&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
            <p><%= listing.location %></p>
            <p><%= listing.country %></p>

            <!-- Calendar Logic -->
            <div class="mb-3">
                <label>Check-in Date:</label>
                <input type="date" id="checkIn" class="form-control" required>
            </div>
            <div class="mb-3">
                <label>Check-out Date:</label>
                <input type="date" id="checkOut" class="form-control" required>
            </div>

            <form method="POST" action="/cart/add/<%= listing._id %>" style="display:inline">
                <button class="btn btn-primary">Add to Cart</button>
            </form>
            <button id="rzp-button" class="btn btn-success">Book Now - &#8377; <%= listing.price.toLocaleString("en-IN") %></button>
        </div>
    </div>

    <!-- Security Verified Edit/Delete -->
    <% if(currUser && listing.owner && currUser._id.toString() === listing.owner._id.toString()) { %>
    <div class="btns offset-3 mb-3">
        <button type="button" onclick="showVerification('edit')" class="btn btn-dark edit-btn">Edit 📝</button>
        <button type="button" onclick="showVerification('delete')" class="btn btn-dark ms-2">Delete</button>
    </div>
    <% } %>

    <!-- Review Section (Restored) -->
    <div class="col-8 offset-3 mb-3 mt-3">
        <hr>
        <% if(currUser) { %>
        <h4>Leave a review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" /> <label for="first-rate1">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" /> <label for="first-rate2">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" /> <label for="first-rate3">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" /> <label for="first-rate4">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" /> <label for="first-rate5">5 stars</label>
            </fieldset>
            <textarea name="review[comment]" class="form-control" rows="5" required></textarea>
            <button class="btn btn-outline-dark mt-3">Submit</button>
        </form>
        <% } %>
        <hr>
        <h4><b>All Reviews</b></h4>
        <div class="row">
            <% for(let review of listing.reviews) { %>
            <div class="card col-md-5 mb-3 ms-3">
                <div class="card-body">
                    <h5 class="card-title">@<%= review.author ? review.author.username : "Anonymous" %></h5>
                    <p class="starability-result" data-rating="<%= review.rating %>"></p>
                    <p class="card-text"><%= review.comment %></p>
                </div>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button class="btn btn-sm btn-dark mb-2 ms-2">Delete</button>
                </form>
            </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Modal (Security) - Ensuring z-index and pointer-events are fine -->
<div id="verifyModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:#fff; padding:20px; border-radius:12px; width:300px; text-align:center;">
        <h5>Security Verification</h5>
        <canvas id="captchaCanvas" style="width:100%; height:60px; background:#f0f0f0; border-radius:5px; margin-bottom:10px;"></canvas>
        <input type="text" id="userInput" placeholder="Type code here" class="form-control">
        <div style="margin-top:15px; display:flex; gap:10px;">
            <button onclick="checkCode()" class="btn btn-success" style="flex:1;">Verify</button>
            <button onclick="closeModal()" class="btn btn-secondary" style="flex:1;">Cancel</button>
        </div>
    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    // Payment Logic
    document.getElementById('rzp-button').onclick = async function() {
        const price = document.getElementById("listing-price").innerText;
        const checkIn = document.getElementById("checkIn").value;
        const checkOut = document.getElementById("checkOut").value;
        if(!checkIn || !checkOut) { alert("Please select dates!"); return; }
        
        const response = await fetch("/payment/create-order", { method: "POST", headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ price }) });
        const order = await response.json();

        const options = {
            "key": "<%= process.env.RAZORPAY_KEY_ID %>",
            "order_id": order.id,
            "name": "Wanderlust",
            "handler": async function (response) {
                const emailRes = await fetch("/payment/send-confirmation", { 
                    method: "POST", headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ paymentId: response.razorpay_payment_id, checkIn, checkOut, listingTitle: "<%= listing.title %>", listingLocation: "<%= listing.location %>" }) 
                });
                if (emailRes.ok) { alert("Payment Success! Confirmation PDF emailed."); window.location.reload(); }
                else { alert("Payment success, but email failed."); }
            },
            "theme": { "color": "#d4af37" }
        };
        new Razorpay(options).open();
    };

    // Modal Logic
    let currentAction = "", generatedCode = "";
    function showVerification(action) {
        currentAction = action;
        generatedCode = Math.random().toString(36).substring(2, 8).toUpperCase();
        document.getElementById('verifyModal').style.display = 'flex';
        let ctx = document.getElementById('captchaCanvas').getContext('2d');
        ctx.clearRect(0, 0, 150, 60); ctx.font = "bold 25px Arial"; ctx.fillText(generatedCode, 25, 40);
    }
    function closeModal() { document.getElementById('verifyModal').style.display = 'none'; }
    function checkCode() {
        let userVal = document.getElementById('userInput').value;
        if (userVal.toUpperCase() === generatedCode) {
            if (currentAction === 'edit') window.location.href = "/listings/<%= listing._id %>/edit";
            else {
                let form = document.createElement('form'); form.method = 'POST'; 
                form.action = '/listings/<%= listing._id %>?_method=DELETE';
                document.body.appendChild(form); form.submit();
            }
        } else { alert("Wrong Code!"); }
    }
</script>